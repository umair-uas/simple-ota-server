# OTA Server Configuration

# URL devices use to download bundles
# Must be reachable from your IoT devices
SERVER_URL=https://ota-gw.local:8443

# Default compatible used by dashboard actions and legacy clients
# Set this to match the 'compatible' field in your device's /etc/rauc/system.conf
DEFAULT_COMPATIBLE=my-board-compatible

# Backward-compatible alias (optional)
# COMPATIBLE=my-board-compatible
